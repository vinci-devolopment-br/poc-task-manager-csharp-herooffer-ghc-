@model IEnumerable<TaskManager.Web.Models.TaskItem>

@{
    ViewData["Title"] = "Gerenciador de Tarefas";
}

<div class="container mt-4">
    <h1>Gerenciador de Tarefas</h1>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="mb-3">
        <a asp-action="Create" class="btn btn-primary">Nova Tarefa</a>
    </div>

    <div class="row mb-3">
        <div class="col-md-6">
            <form id="orderForm" class="form-inline">
                <label for="orderSelect" class="form-label me-2">Ordenar por:</label>
                <select id="orderSelect" name="order" class="form-select d-inline w-auto">
                    <option value="desc" selected="@(ViewBag.Order == "desc" ? "selected" : null)">Mais recentes</option>
                    <option value="asc" selected="@(ViewBag.Order == "asc" ? "selected" : null)">Mais antigas</option>
                </select>
            </form>
        </div>
    </div>

    <div id="task-list-container">
        @await Html.PartialAsync("_TaskListPartial", Model)
    </div>

    <nav aria-label="Paginação de tarefas">
        <ul class="pagination justify-content-center" id="pagination-container">
            @for (int i = 1; i <= (int)ViewBag.TotalPages; i++)
            {
                <li class="page-item @(i == (int)ViewBag.CurrentPage ? "active" : "")">
                    <a class="page-link" href="#" data-page="@i">@i</a>
                </li>
            }
        </ul>
    </nav>

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script>
        $(document).ready(function () {
            function loadTasks(page, order) {
                $.get('@Url.Action("TaskListPartial", "Tasks")', { page: page, order: order }, function (data) {
                    $('#task-list-container').html(data);
                    // Atualiza paginação
                    $(".pagination .page-item").removeClass("active");
                    $(".pagination .page-link[data-page=" + page + "]").parent().addClass("active");
                });
            }
            $(document).on('click', '.page-link', function (e) {
                e.preventDefault();
                var page = $(this).data('page');
                var order = $('#orderSelect').val();
                loadTasks(page, order);
            });
            $('#orderSelect').on('change', function () {
                var order = $(this).val();
                loadTasks(1, order);
            });
        });
    </script>
</div>
